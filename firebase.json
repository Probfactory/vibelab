{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "firestore.rules", ".firebase", ".git", ".claude", "node_modules"],
    "cleanUrls": true,
    "rewrites": [
      { "source": "/explore", "destination": "/explore.html" },
      { "source": "/feed", "destination": "/explore.html" },
      { "source": "/community", "destination": "/community.html" },
      { "source": "/profile", "destination": "/profile.html" },
      { "source": "/vibe", "destination": "/vibe.html" },
      { "source": "/project", "destination": "/vibe.html" },
      { "source": "/my-vibes", "destination": "/my-vibes.html" },
      { "source": "/admin", "destination": "/admin.html" },
      { "source": "/reset-password", "destination": "/reset-password.html" },
      { "source": "/:username", "destination": "/profile.html" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
