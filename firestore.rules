rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isActiveUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    // Protected fields that regular users cannot write
    function notChangingProtectedFields() {
      let protectedFields = ['role', 'invitesRemaining', 'status', 'invitedBy', 'inviteCode'];
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny(protectedFields.toSet());
    }

    // Block role field on profile creation to prevent privilege escalation
    function noRoleOnCreate() {
      return !request.resource.data.keys().hasAny(['role'].toSet());
    }

    // ── Users collection ──

    match /users/{userId} {
      // Anyone can read individual profiles (public profiles)
      allow get: if true;
      // Only authenticated users can list/query users (prevents anonymous scraping)
      allow list: if isSignedIn();

      // Users can create their own profile on signup
      // Block role field on creation to prevent privilege escalation
      allow create: if isOwner(userId) && noRoleOnCreate();

      // Users can update their own profile but NOT protected fields
      // Superadmin can update any user including protected fields
      // Special case: users can decrement their own invitesRemaining by 1 (invite generation)
      allow update: if isSuperAdmin()
        || (isOwner(userId) && notChangingProtectedFields())
        || (isOwner(userId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['invitesRemaining'])
            && request.resource.data.invitesRemaining == resource.data.invitesRemaining - 1);

      // Only superadmin can delete users
      allow delete: if isSuperAdmin() || isOwner(userId);

      // User subcollections (collections)
      match /collections/{collectionId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // ── Usernames collection (vanity URL mapping) ──

    match /usernames/{username} {
      // Anyone can read (needed for profile lookups and availability checks)
      allow read: if true;

      // Authenticated users can claim a username during signup
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;

      // Only the owner or superadmin can delete a username claim
      allow delete: if isSuperAdmin()
        || (isSignedIn() && resource.data.uid == request.auth.uid);

      // Only superadmin can update (shouldn't normally happen)
      allow update: if isSuperAdmin();
    }

    // ── Projects collection ──

    match /projects/{projectId} {
      // Anyone can read public projects
      allow read: if true;

      // Authenticated active users can create projects
      // Validate required fields and prevent stat inflation
      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'description', 'authorUid'])
        && (!request.resource.data.keys().hasAny(['vibes', 'comments'])
            || (request.resource.data.vibes == 0 && request.resource.data.comments == 0));

      // Only the author can update/delete their own projects
      // Superadmin can also update/delete any project
      allow update: if isSuperAdmin()
        || (isSignedIn() && resource.data.authorUid == request.auth.uid);

      allow delete: if isSuperAdmin()
        || (isSignedIn() && resource.data.authorUid == request.auth.uid);

      // Vibes (likes) subcollection
      match /vibes/{vibeId} {
        allow read: if true;
        allow create: if isSignedIn() && vibeId == request.auth.uid;
        allow delete: if isSignedIn() && vibeId == request.auth.uid;
      }

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.keys().hasAll(['authorUid', 'body']);
        allow update: if isSignedIn()
          && resource.data.authorUid == request.auth.uid;
        allow delete: if isSuperAdmin()
          || (isSignedIn() && resource.data.authorUid == request.auth.uid);
      }
    }

    // ── Follows collection ──

    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.followerId == request.auth.uid;
    }

    // ── Tag follows collection ──

    match /tag_follows/{tagFollowId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ── Invite codes collection ──
    // NOTE: This collection is publicly readable because the invite landing page
    // validates codes via .where('code', '==', ...) for unauthenticated users.
    // To fully lock this down, move invite validation to a Cloud Function.

    match /inviteCodes/{codeId} {
      allow read: if true;

      // Superadmin can create any code
      // Regular users can create codes (user-generated invites)
      allow create: if isSuperAdmin()
        || (isSignedIn() && request.resource.data.createdBy == request.auth.uid
            && request.resource.data.type == 'user');

      // Superadmin can update any code
      // Anyone authenticated can mark a code as used during signup (redeem)
      allow update: if isSuperAdmin()
        || (isSignedIn()
            && resource.data.status == 'active'
            && request.resource.data.status == 'used'
            && request.resource.data.usedBy == request.auth.uid);

      // Only superadmin can delete codes
      allow delete: if isSuperAdmin();
    }

    // ── Admin metadata (for bootstrap check) ──

    match /adminConfig/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin()
        || (isSignedIn() && !exists(/databases/$(database)/documents/adminConfig/settings));
    }
  }
}
